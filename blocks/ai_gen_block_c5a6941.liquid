      "type": "textarea",
      "id": "section_subtitle",
      "label": "Subtitle",
      "default": "Discover the benefits that set us apart"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "columns_desktop",
