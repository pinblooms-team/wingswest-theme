{% doc %}
  @prompt
    Create an icon grid section with customizable icons and text labels. Each icon card should have a hover effect with smooth transitions. The section should allow merchants to add multiple icon items, where each item includes an icon image upload field, a heading field for the label text, and optional description text. Add hover effects like scale transform, shadow elevation, or color overlay. Include settings to control the number of columns (2-4 columns), icon size, spacing, background colors, and hover animation style. Make it responsive for mobile devices with automatic column stacking.
    
    SCROLL LINKING FEATURE: Each item can have a scroll target ID to link to specific sections on the page (e.g., FAQ sections with IDs like "block-separator_APta66").
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-icon-grid-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 40px 20px;
    background-color: {{ block.settings.section_background }};
  }

  .ai-icon-grid__container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-icon-grid__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
  }

  .ai-icon-grid__title-{{ ai_gen_id }} {
    font-size: 32px;
    font-weight: 600;
    color: {{ block.settings.heading_color }};
    margin: 0 0 12px;
  }

  .ai-icon-grid__subtitle-{{ ai_gen_id }} {
    font-size: 16px;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-icon-grid__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-icon-grid__item-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    text-align: center;
    transition: all 0.3s ease;
    border: 1px solid {{ block.settings.card_border_color }};
    cursor: pointer;
  }

  {% if block.settings.hover_effect == 'scale' %}
    .ai-icon-grid__item-{{ ai_gen_id }}:hover {
      border-color: #ff2d37;
    }
  {% elsif block.settings.hover_effect == 'lift' %}
    .ai-icon-grid__item-{{ ai_gen_id }}:hover {
      transform: translateY(-8px);
      box-shadow: 0 12px 32px rgba(0, 0, 0, 0.15);
    }
  {% elsif block.settings.hover_effect == 'shadow' %}
    .ai-icon-grid__item-{{ ai_gen_id }}:hover {
      box-shadow: 0 12px 32px rgba(0, 0, 0, 0.15);
    }
  {% elsif block.settings.hover_effect == 'overlay' %}
    .ai-icon-grid__item-{{ ai_gen_id }} {
      position: relative;
      overflow: hidden;
    }
    .ai-icon-grid__item-{{ ai_gen_id }}::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background-color: {{ block.settings.hover_overlay_color }};
      opacity: 0;
      transition: opacity 0.3s ease;
      pointer-events: none;
    }
    .ai-icon-grid__item-{{ ai_gen_id }}:hover::before {
      opacity: 0.1;
    }
    .ai-icon-grid__item-{{ ai_gen_id }}:hover {
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
    }
  {% endif %}

  .ai-icon-grid__icon-wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    margin: 0 auto {{ block.settings.icon_spacing }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-icon-grid__icon-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-icon-grid__icon-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-icon-grid__icon-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-icon-grid__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.item_heading_size }}px;
    font-weight: 600;
    color: {{ block.settings.item_heading_color }};
    margin: 0 0 8px;
  }

  .ai-icon-grid__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.item_description_size }}px;
    color: {{ block.settings.item_description_color }};
    margin: 0;
    line-height: 1.5;
  }

  @media screen and (max-width: 989px) {
    .ai-icon-grid__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }

    .ai-icon-grid__title-{{ ai_gen_id }} {
      font-size: 28px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-icon-grid-{{ ai_gen_id }} {
      padding: 20px 0px;
    }

    .ai-icon-grid__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
      gap: {{ block.settings.grid_gap | times: 0.75 }}px;
    }

    .ai-icon-grid__title-{{ ai_gen_id }} {
      font-size: 24px;
    }

    .ai-icon-grid__icon-wrapper-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.8 }}px;
      height: {{ block.settings.icon_size | times: 0.8 }}px;
    }

    .ai-icon-grid__item-{{ ai_gen_id }} {
      padding: 10px;
    }
  }
{% endstyle %}

<icon-grid-{{ ai_gen_id }} class="ai-icon-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-icon-grid__container-{{ ai_gen_id }}">
    {% if block.settings.section_title != blank or block.settings.section_subtitle != blank %}
      <div class="ai-icon-grid__header-{{ ai_gen_id }}">
        {% if block.settings.section_title != blank %}
          <h2 class="ai-icon-grid__title-{{ ai_gen_id }}">{{ block.settings.section_title }}</h2>
        {% endif %}
        {% if block.settings.section_subtitle != blank %}
          <p class="ai-icon-grid__subtitle-{{ ai_gen_id }}">{{ block.settings.section_subtitle }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-icon-grid__grid-{{ ai_gen_id }}">
      {% for i in (1..12) %}
        {% liquid
          assign enabled_key = 'item_' | append: i | append: '_enabled'
          assign icon_key = 'item_' | append: i | append: '_icon'
          assign heading_key = 'item_' | append: i | append: '_heading'
          assign description_key = 'item_' | append: i | append: '_description'
          assign link_key = 'item_' | append: i | append: '_link'
          assign scroll_target_key = 'item_' | append: i | append: '_scroll_target'

          assign item_enabled = block.settings[enabled_key]
          assign item_icon = block.settings[icon_key]
          assign item_heading = block.settings[heading_key]
          assign item_description = block.settings[description_key]
          assign item_link = block.settings[link_key]
          assign item_scroll_target = block.settings[scroll_target_key]
        %}

        {% if item_enabled %}
          {% if item_link != blank %}
            <a href="{{ item_link }}" class="ai-icon-grid__item-{{ ai_gen_id }}" style="text-decoration: none;">
          {% else %}
            <div class="ai-icon-grid__item-{{ ai_gen_id }}" {% if item_scroll_target != blank %}data-scroll-target="{{ item_scroll_target }}"{% endif %}>
          {% endif %}
              <div class="ai-icon-grid__icon-wrapper-{{ ai_gen_id }}">
                {% if item_icon %}
                  <img
                    src="{{ item_icon | image_url: width: 400 }}"
                    alt="{{ item_heading | escape }}"
                    class="ai-icon-grid__icon-{{ ai_gen_id }}"
                    loading="lazy"
                    width="400"
                    height="400"
                  >
                {% else %}
                  <div class="ai-icon-grid__icon-placeholder-{{ ai_gen_id }}">
                    {{ 'image' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </div>

              {% if item_heading != blank %}
                <h3 class="ai-icon-grid__heading-{{ ai_gen_id }}">{{ item_heading }}</h3>
              {% endif %}

              {% if item_description != blank %}
                <div class="ai-icon-grid__description-{{ ai_gen_id }}">{{ item_description }}</div>
              {% endif %}
          {% if item_link != blank %}
            </a>
          {% else %}
            </div>
          {% endif %}
        {% endif %}
      {% endfor %}
    </div>
  </div>
</icon-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class IconGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.items = this.querySelectorAll('.ai-icon-grid__item-{{ ai_gen_id }}');
        this.setupAccessibility();
        this.setupScrollLinking();
      }

      setupAccessibility() {
        this.items.forEach((item) => {
          if (!item.hasAttribute('href')) {
            item.setAttribute('tabindex', '0');
            item.setAttribute('role', 'article');
          }
        });
      }

      setupScrollLinking() {
        this.items.forEach((item) => {
          const scrollTarget = item.dataset.scrollTarget;
          
          if (scrollTarget) {
            // Add click event
            item.addEventListener('click', (e) => {
              this.scrollToTarget(scrollTarget);
            });

            // Add keyboard support (Enter and Space)
            item.addEventListener('keydown', (e) => {
              if (e.key === 'Enter' || e.key === ' ') {
                e.preventDefault();
                this.scrollToTarget(scrollTarget);
              }
            });
          }
        });
      }

      scrollToTarget(targetId) {
        // Try to find the target element by ID
        let targetElement = document.getElementById(targetId);
        
        // If not found with exact ID, try with prepended #
        if (!targetElement && !targetId.startsWith('#')) {
          targetElement = document.getElementById('#' + targetId);
        }
        
        // If still not found, try querySelector
        if (!targetElement) {
          targetElement = document.querySelector(targetId);
        }

        // If still not found, try finding by data attribute or class
        if (!targetElement) {
          targetElement = document.querySelector(`[id="${targetId}"]`) || 
                         document.querySelector(`[data-id="${targetId}"]`) ||
                         document.querySelector(`.${targetId}`);
        }

        if (targetElement) {
          // Calculate offset for fixed headers (adjust if needed)
          const offset = {{ block.settings.scroll_offset }};
          const targetPosition = targetElement.getBoundingClientRect().top + window.pageYOffset - offset;

          // Smooth scroll to target
          window.scrollTo({
            top: targetPosition,
            behavior: 'smooth'
          });

          // Optional: Add focus to target for accessibility
          setTimeout(() => {
            targetElement.setAttribute('tabindex', '-1');
            targetElement.focus();
            targetElement.style.outline = 'none';
          }, 500);
        } else {
          console.warn(`Scroll target not found: ${targetId}`);
        }
      }
    }

    customElements.define('icon-grid-{{ ai_gen_id }}', IconGrid{{ ai_gen_id }});
  })();
</script>

