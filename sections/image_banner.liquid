{% comment %}
  @prompt
    Create a split-screen section with a slider (80% width) and product carousel (20% width). SLIDER: Auto-play image slideshow that cycles automatically, with left/right navigation arrows that only appear on hover. Images must display fully without cropping, maintaining their aspect ratio. Include smooth fade or slide transitions. CAROUSEL (DAILY DEAL): Pull products from a selected collection. DESKTOP: Show ONLY 1 product at a time, user can click left/right arrows to browse through entire collection. TABLET: Show 2 products. MOBILE: Show 3 products. Each product card displays: product image, title, price, wishlist heart icon, settings/compare icon, and red ADD TO CART button. Both components work independently. Fully responsive: 80/20 split on desktop, 70/30 on tablet, stacked vertically on mobile (slider on top, carousel below). Use modern styling with proper spacing and smooth animations.
{% endcomment %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-split-screen-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    max-width: 100%;
  }

  .ai-split-screen-container-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.gap }}px;
    width: 85%;
  }

  .ai-slider-section-{{ ai_gen_id }} {
    flex: 0 0 {{ block.settings.slider_width_desktop }}%;
    position: relative;
    background-color: {{ block.settings.slider_background }};
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
  }

  .ai-slider-wrapper-{{ ai_gen_id }} {
    position: relative;
    /* width: 80%; */
    height: {{ block.settings.slider_height }}px;
  }

  .ai-slider-track-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .ai-slide-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    transition: opacity {{ block.settings.transition_speed }}s ease-in-out;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-slide-{{ ai_gen_id }}.active {
    opacity: 1;
    z-index: 1;
  }

  .ai-slide-{{ ai_gen_id }} img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    display: block;
  }

  .ai-slide-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-slide-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 400px;
    max-height: 400px;
  }

  .ai-slider-nav-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background-color: {{ block.settings.arrow_background }};
    color: {{ block.settings.arrow_color }};
    border: none;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    opacity: 0;
    transition: opacity 0.3s ease, background-color 0.3s ease;
  }

  .ai-slider-section-{{ ai_gen_id }}:hover .ai-slider-nav-{{ ai_gen_id }} {
    opacity: 1;
  }

  .ai-slider-nav-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.arrow_hover_background }};
  }

  .ai-slider-nav-prev-{{ ai_gen_id }} {
    left: 20px;
  }

  .ai-slider-nav-next-{{ ai_gen_id }} {
    right: 20px;
  }

  .ai-slider-nav-{{ ai_gen_id }} svg {
    width: 24px;
    height: 24px;
  }

  /* Dot indicators */
  .ai-slider-dots-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 10px;
    z-index: 2;
  }

  .ai-slider-dot-{{ ai_gen_id }} {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    border: 2px solid {{ block.settings.dot_border_color }};
    cursor: pointer;
    transition: all 0.3s ease;
    opacity: 0.5;
  }

  .ai-slider-dot-{{ ai_gen_id }}.active {
    opacity: 1;
    background-color: {{ block.settings.dot_active_color }};
    transform: scale(1.2);
  }

  .ai-slider-dot-{{ ai_gen_id }}:hover {
    opacity: 0.8;
    transform: scale(1.1);
  }

  .ai-carousel-section-{{ ai_gen_id }} {
    flex: 0 0 calc(100% - {{ block.settings.slider_width_desktop }}%);
    position: relative;
    background-color: {{ block.settings.carousel_background }};
    border-radius: {{ block.settings.border_radius }}px;
    padding: 20px;
    display: flex;
    flex-direction: column;
    min-height: {{ block.settings.slider_height }}px;
  }

  /* Mobile stacking order */
  .ai-split-screen-container-{{ ai_gen_id }}.reverse-mobile {
    flex-direction: column-reverse;
  }

  .ai-carousel-header-{{ ai_gen_id }} {
    margin-bottom: 20px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .ai-carousel-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.carousel_title_size }}px;
    color: {{ block.settings.carousel_title_color }};
    margin: 0;
    font-weight: 600;
  }

  /* NEW: Header navigation buttons */
  .ai-carousel-header-nav-{{ ai_gen_id }} {
    display: flex;
    gap: 8px;
  }

  .ai-carousel-header-nav-btn-{{ ai_gen_id }} {
    background-color: {{ block.settings.carousel_arrow_background }};
    color: {{ block.settings.carousel_arrow_color }};
    border: none;
    width: 32px;
    height: 32px;
    border-radius: 4px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.3s ease, opacity 0.3s ease;
  }

  .ai-carousel-header-nav-btn-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.carousel_arrow_hover }};
  }

  .ai-carousel-header-nav-btn-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-carousel-header-nav-btn-{{ ai_gen_id }} svg {
    width: 16px;
    height: 16px;
  }

  .ai-carousel-wrapper-{{ ai_gen_id }} {
    position: relative;
    flex: 1;
    overflow: hidden;
    display: flex;
    align-items: center;
  }

  .ai-carousel-track-{{ ai_gen_id }} {
    display: flex;
    transition: transform 0.4s ease;
    width: 100%;
  }

  .ai-product-card-{{ ai_gen_id }} {
    flex: 0 0 100%;
    padding: 0 10px;
    box-sizing: border-box;
  }

  .ai-product-card-inner-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: 15px;
    height: 100%;
    display: flex;
    flex-direction: column;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .ai-product-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    margin-bottom: 15px;
    overflow: hidden;
    border-radius: {{ block.settings.card_border_radius }}px;
  }

  .ai-product-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-product-image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-product-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
  }

  .ai-product-icons-{{ ai_gen_id }} {
    position: absolute;
    top: 10px;
    right: 10px;
    display: flex;
    gap: 8px;
    z-index: 1;
  }

  .ai-product-icon-btn-{{ ai_gen_id }} {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background-color: {{ block.settings.icon_background }};
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.3s ease;
  }

  .ai-product-icon-btn-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.icon_hover_background }};
  }

  .ai-product-icon-btn-{{ ai_gen_id }} svg {
    width: 18px;
    height: 18px;
    fill: none;
    stroke: {{ block.settings.icon_color }};
  }

  .ai-product-info-{{ ai_gen_id }} {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: 10px 0 0;
  }

  .ai-product-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_title_size }}px;
    color: {{ block.settings.product_title_color }};
    margin: 0 0 10px;
    font-weight: 600;
    line-height: 1.3;
  }

  .ai-product-title-{{ ai_gen_id }} a {
    color: inherit;
    text-decoration: none;
  }

  .ai-product-title-{{ ai_gen_id }} a:hover {
    text-decoration: underline;
  }

  .ai-product-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_price_size }}px;
    color: {{ block.settings.product_price_color }};
    margin-bottom: 15px;
    font-weight: 700;
  }

  .ai-add-to-cart-btn-{{ ai_gen_id }} {
    background-color: {{ block.settings.cart_button_background }};
    color: {{ block.settings.cart_button_text_color }};
    border: none;
    padding: 12px 20px;
    border-radius: {{ block.settings.cart_button_radius }}px;
    font-size: {{ block.settings.cart_button_size }}px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.3s ease;
    margin-top: auto;
    width: 100%;
  }

  .ai-add-to-cart-btn-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.cart_button_hover }};
  }

  /* OLD carousel nav buttons - HIDDEN */
  .ai-carousel-nav-{{ ai_gen_id }} {
    display: none;
  }

  .ai-empty-collection-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
    color: #999;
    font-style: italic;
    text-align: center;
    padding: 20px;
  }

  /* TABLET - 2 products visible */
  @media screen and (max-width: 989px) {
    .ai-slider-section-{{ ai_gen_id }} {
      flex: 0 0 {{ block.settings.slider_width_tablet }}%;
    }

    .ai-carousel-section-{{ ai_gen_id }} {
      flex: 0 0 calc(100% - {{ block.settings.slider_width_tablet }}%);
      min-height: {{ block.settings.slider_height | times: 0.8 }}px;
    }

    .ai-product-card-{{ ai_gen_id }} {
      flex: 0 0 {{ 100 | divided_by: block.settings.tablet_products_visible }}%;
    }

    .ai-slider-wrapper-{{ ai_gen_id }} {
      height: {{ block.settings.slider_height | times: 0.8 }}px;
    }
  }

  /* MOBILE - Stacked layout, 3 products visible */
  @media screen and (max-width: 749px) {
    .ai-split-screen-container-{{ ai_gen_id }} {
      {% if block.settings.mobile_stack_order == 'carousel_first' %}
        flex-direction: column-reverse;
      {% else %}
        flex-direction: column;
      {% endif %}
    }

    .ai-slider-section-{{ ai_gen_id }} {
      flex: 0 0 100%;
    }

    .ai-carousel-section-{{ ai_gen_id }} {
      flex: 0 0 100%;
      min-height: auto;
    }

    .ai-product-card-{{ ai_gen_id }} {
      flex: 0 0 {{ 100 | divided_by: block.settings.mobile_products_visible }}%;
    }

    .ai-slider-wrapper-{{ ai_gen_id }} {
      height: {{ block.settings.slider_height | times: 0.6 }}px;
    }

    .ai-slider-nav-{{ ai_gen_id }} {
      width: 40px;
      height: 40px;
    }

    .ai-slider-nav-prev-{{ ai_gen_id }} {
      left: 10px;
    }

    .ai-slider-nav-next-{{ ai_gen_id }} {
      right: 10px;
    }

    .ai-carousel-header-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
    }

    .ai-slider-dots-{{ ai_gen_id }} {
      bottom: 15px;
      gap: 8px;
    }

    .ai-slider-dot-{{ ai_gen_id }} {
      width: 10px;
      height: 10px;
    }
  }
{% endstyle %}

<split-screen-slider-{{ ai_gen_id }} class="ai-split-screen-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-split-screen-container-{{ ai_gen_id }}">
    <div class="ai-slider-section-{{ ai_gen_id }}">
      <div class="ai-slider-wrapper-{{ ai_gen_id }}">
        <div class="ai-slider-track-{{ ai_gen_id }}">
          {% for i in (1..5) %}
            {% assign image_key = 'slider_image_' | append: i %}
            {% assign image = block.settings[image_key] %}
            
            {% if image != blank %}
              <div class="ai-slide-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}" data-slide="{{ forloop.index }}">
                <img
                  src="{{ image | image_url: width: 2000 }}"
                  alt="{{ image.alt | escape }}"
                  loading="lazy"
                  width="{{ image.width }}"
                  height="{{ image.height }}"
                >
              </div>
            {% elsif forloop.first %}
              <div class="ai-slide-{{ ai_gen_id }} active" data-slide="{{ forloop.index }}">
                <div class="ai-slide-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              </div>
            {% endif %}
          {% endfor %}
        </div>

        <button class="ai-slider-nav-{{ ai_gen_id }} ai-slider-nav-prev-{{ ai_gen_id }}" aria-label="Previous slide">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
        </button>

        <button class="ai-slider-nav-{{ ai_gen_id }} ai-slider-nav-next-{{ ai_gen_id }}" aria-label="Next slide">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </button>

        {% if block.settings.show_dots %}
          <div class="ai-slider-dots-{{ ai_gen_id }}">
            {% for i in (1..5) %}
              {% assign image_key = 'slider_image_' | append: i %}
              {% assign image = block.settings[image_key] %}
              {% if image != blank %}
                <button 
                  class="ai-slider-dot-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}" 
                  data-slide-index="{{ forloop.index | minus: 1 }}"
                  aria-label="Go to slide {{ forloop.index }}"
                ></button>
              {% endif %}
            {% endfor %}
          </div>
        {% endif %}
      </div>
    </div>

    <div class="ai-carousel-section-{{ ai_gen_id }}">
      <div class="ai-carousel-header-{{ ai_gen_id }}">
        {% if block.settings.carousel_title != blank %}
          <h2 class="ai-carousel-title-{{ ai_gen_id }}">{{ block.settings.carousel_title }}</h2>
        {% endif %}

        {% if block.settings.product_collection != blank and block.settings.product_collection.products.size > 1 %}
          <div class="ai-carousel-header-nav-{{ ai_gen_id }}">
            <button class="ai-carousel-header-nav-btn-{{ ai_gen_id }} ai-carousel-nav-prev-{{ ai_gen_id }}" aria-label="Previous product">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="15 18 9 12 15 6"></polyline>
              </svg>
            </button>

            <button class="ai-carousel-header-nav-btn-{{ ai_gen_id }} ai-carousel-nav-next-{{ ai_gen_id }}" aria-label="Next product">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="9 18 15 12 9 6"></polyline>
              </svg>
            </button>
          </div>
        {% endif %}
      </div>

      {% if block.settings.product_collection != blank and block.settings.product_collection.products.size > 0 %}
        <div class="ai-carousel-wrapper-{{ ai_gen_id }}">
          <div class="ai-carousel-track-{{ ai_gen_id }}">
            {% for product in block.settings.product_collection.products %}
              <div class="ai-product-card-{{ ai_gen_id }}">
                <div class="ai-product-card-inner-{{ ai_gen_id }}">
                  <div class="ai-product-image-wrapper-{{ ai_gen_id }}">
                    {% if product.featured_image %}
                      <img
                        src="{{ product.featured_image | image_url: width: 500 }}"
                        alt="{{ product.featured_image.alt | escape }}"
                        class="ai-product-image-{{ ai_gen_id }}"
                        loading="lazy"
                        width="500"
                        height="500"
                      >
                    {% else %}
                      <div class="ai-product-image-placeholder-{{ ai_gen_id }}">
                        {{ 'product-1' | placeholder_svg_tag }}
                      </div>
                    {% endif %}

                    <div class="ai-product-icons-{{ ai_gen_id }}">
                      <button class="ai-product-icon-btn-{{ ai_gen_id }}" aria-label="Add to wishlist">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
                        </svg>
                      </button>
                      <button class="ai-product-icon-btn-{{ ai_gen_id }}" aria-label="Compare">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <circle cx="12" cy="12" r="3"></circle>
                          <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
                        </svg>
                      </button>
                    </div>
                  </div>

                  <div class="ai-product-info-{{ ai_gen_id }}">
                    <h3 class="ai-product-title-{{ ai_gen_id }}">
                      <a href="{{ product.url }}">{{ product.title }}</a>
                    </h3>
                    <div class="ai-product-price-{{ ai_gen_id }}">
                      {{ product.price | money }}
                    </div>
                    <button class="ai-add-to-cart-btn-{{ ai_gen_id }}" data-product-id="{{ product.selected_or_first_available_variant.id }}">
                      {{ block.settings.cart_button_label }}
                    </button>
                  </div>
                </div>
              </div>
            {% endfor %}
          </div>
        </div>
      {% else %}
        <div class="ai-empty-collection-{{ ai_gen_id }}">
          Next, select a collection to display products
        </div>
      {% endif %}
    </div>
  </div>
</split-screen-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class SplitScreenSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.sliderCurrentIndex = 0;
        this.carouselCurrentIndex = 0;
        this.sliderAutoplayInterval = null;
        this.carouselAutoplayInterval = null;
        this.isSliderPaused = false;
      }

      connectedCallback() {
        // Slider elements
        this.slides = this.querySelectorAll('.ai-slide-{{ ai_gen_id }}');
        this.sliderPrevBtn = this.querySelector('.ai-slider-nav-prev-{{ ai_gen_id }}');
        this.sliderNextBtn = this.querySelector('.ai-slider-nav-next-{{ ai_gen_id }}');
        this.sliderDots = this.querySelectorAll('.ai-slider-dot-{{ ai_gen_id }}');
        this.sliderSection = this.querySelector('.ai-slider-section-{{ ai_gen_id }}');
        
        // Carousel elements
        this.carouselTrack = this.querySelector('.ai-carousel-track-{{ ai_gen_id }}');
        this.carouselCards = this.querySelectorAll('.ai-product-card-{{ ai_gen_id }}');
        this.carouselPrevBtn = this.querySelector('.ai-carousel-nav-prev-{{ ai_gen_id }}');
        this.carouselNextBtn = this.querySelector('.ai-carousel-nav-next-{{ ai_gen_id }}');
        this.addToCartBtns = this.querySelectorAll('.ai-add-to-cart-btn-{{ ai_gen_id }}');

        this.setupSlider();
        this.setupCarousel();
        this.setupAddToCart();
        this.setupKeyboardNavigation();

        window.addEventListener('resize', () => this.updateCarousel());
      }

      setupSlider() {
        if (this.slides.length === 0) return;

        // Navigation buttons
        if (this.sliderPrevBtn) {
          this.sliderPrevBtn.addEventListener('click', () => this.prevSlide());
        }

        if (this.sliderNextBtn) {
          this.sliderNextBtn.addEventListener('click', () => this.nextSlide());
        }

        // Dot indicators
        this.sliderDots.forEach((dot, index) => {
          dot.addEventListener('click', () => this.goToSlide(index));
        });

        // Pause on hover
        {% if block.settings.pause_on_hover %}
          if (this.sliderSection) {
            this.sliderSection.addEventListener('mouseenter', () => {
              this.isSliderPaused = true;
              this.pauseSliderAutoplay();
            });

            this.sliderSection.addEventListener('mouseleave', () => {
              this.isSliderPaused = false;
              this.startSliderAutoplay();
            });
          }
        {% endif %}

        // Touch/swipe support for slider
        let touchStartX = 0;
        let touchEndX = 0;

        if (this.sliderSection) {
          this.sliderSection.addEventListener('touchstart', (e) => {
            touchStartX = e.changedTouches[0].screenX;
          }, { passive: true });

          this.sliderSection.addEventListener('touchend', (e) => {
            touchEndX = e.changedTouches[0].screenX;
            this.handleSliderSwipe(touchStartX, touchEndX);
          }, { passive: true });
        }

        // Start autoplay
        {% if block.settings.autoplay %}
          this.startSliderAutoplay();
        {% endif %}
      }

      handleSliderSwipe(startX, endX) {
        const swipeThreshold = 50;
        const diff = startX - endX;

        if (Math.abs(diff) > swipeThreshold) {
          if (diff > 0) {
            this.nextSlide();
          } else {
            this.prevSlide();
          }
        }
      }

      prevSlide() {
        this.sliderCurrentIndex = (this.sliderCurrentIndex - 1 + this.slides.length) % this.slides.length;
        this.updateSlider();
        this.resetSliderAutoplay();
      }

      nextSlide() {
        this.sliderCurrentIndex = (this.sliderCurrentIndex + 1) % this.slides.length;
        this.updateSlider();
        this.resetSliderAutoplay();
      }

      goToSlide(index) {
        this.sliderCurrentIndex = index;
        this.updateSlider();
        this.resetSliderAutoplay();
      }

      updateSlider() {
        // Update slides
        this.slides.forEach((slide, index) => {
          if (index === this.sliderCurrentIndex) {
            slide.classList.add('active');
          } else {
            slide.classList.remove('active');
          }
        });

        // Update dots
        this.sliderDots.forEach((dot, index) => {
          if (index === this.sliderCurrentIndex) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }

      startSliderAutoplay() {
        {% if block.settings.autoplay %}
          if (this.isSliderPaused) return;
          this.pauseSliderAutoplay();
          this.sliderAutoplayInterval = setInterval(() => {
            this.nextSlide();
          }, {{ block.settings.autoplay_speed }} * 1000);
        {% endif %}
      }

      pauseSliderAutoplay() {
        if (this.sliderAutoplayInterval) {
          clearInterval(this.sliderAutoplayInterval);
          this.sliderAutoplayInterval = null;
        }
      }

      resetSliderAutoplay() {
        {% if block.settings.autoplay %}
          this.pauseSliderAutoplay();
          this.startSliderAutoplay();
        {% endif %}
      }

      setupCarousel() {
        if (!this.carouselTrack || this.carouselCards.length === 0) return;

        if (this.carouselPrevBtn) {
          this.carouselPrevBtn.addEventListener('click', () => this.prevProduct());
        }

        if (this.carouselNextBtn) {
          this.carouselNextBtn.addEventListener('click', () => this.nextProduct());
        }

        // Touch/swipe support for carousel
        let touchStartX = 0;
        let touchEndX = 0;

        this.carouselTrack.addEventListener('touchstart', (e) => {
          touchStartX = e.changedTouches[0].screenX;
        }, { passive: true });

        this.carouselTrack.addEventListener('touchend', (e) => {
          touchEndX = e.changedTouches[0].screenX;
          this.handleCarouselSwipe(touchStartX, touchEndX);
        }, { passive: true });

        this.updateCarousel();

        // Start carousel autoplay
        {% if block.settings.carousel_autoplay %}
          this.startCarouselAutoplay();
        {% endif %}
      }

      handleCarouselSwipe(startX, endX) {
        const swipeThreshold = 50;
        const diff = startX - endX;

        if (Math.abs(diff) > swipeThreshold) {
          if (diff > 0) {
            this.nextProduct();
          } else {
            this.prevProduct();
          }
        }
      }

      prevProduct() {
        this.carouselCurrentIndex = Math.max(0, this.carouselCurrentIndex - 1);
        this.updateCarousel();
        this.resetCarouselAutoplay();
      }

      nextProduct() {
        const maxIndex = this.carouselCards.length - this.getVisibleCards();
        this.carouselCurrentIndex = Math.min(maxIndex, this.carouselCurrentIndex + 1);
        this.updateCarousel();
        this.resetCarouselAutoplay();
      }

      getVisibleCards() {
        const width = window.innerWidth;
        if (width <= 749) return {{ block.settings.mobile_products_visible }};
        if (width <= 989) return {{ block.settings.tablet_products_visible }};
        return {{ block.settings.desktop_products_visible }};
      }

      updateCarousel() {
        if (!this.carouselTrack || this.carouselCards.length === 0) return;

        const cardWidth = this.carouselCards[0].offsetWidth;
        const offset = -this.carouselCurrentIndex * cardWidth;
        this.carouselTrack.style.transform = `translateX(${offset}px)`;

        if (this.carouselPrevBtn) {
          this.carouselPrevBtn.disabled = this.carouselCurrentIndex === 0;
        }

        if (this.carouselNextBtn) {
          const maxIndex = this.carouselCards.length - this.getVisibleCards();
          this.carouselNextBtn.disabled = this.carouselCurrentIndex >= maxIndex;
        }
      }

      startCarouselAutoplay() {
        {% if block.settings.carousel_autoplay %}
          this.pauseCarouselAutoplay();
          this.carouselAutoplayInterval = setInterval(() => {
            const maxIndex = this.carouselCards.length - this.getVisibleCards();
            if (this.carouselCurrentIndex >= maxIndex) {
              this.carouselCurrentIndex = 0;
            } else {
              this.carouselCurrentIndex++;
            }
            this.updateCarousel();
          }, {{ block.settings.carousel_autoplay_speed }} * 1000);
        {% endif %}
      }

      pauseCarouselAutoplay() {
        if (this.carouselAutoplayInterval) {
          clearInterval(this.carouselAutoplayInterval);
          this.carouselAutoplayInterval = null;
        }
      }

      resetCarouselAutoplay() {
        {% if block.settings.carousel_autoplay %}
          this.pauseCarouselAutoplay();
          this.startCarouselAutoplay();
        {% endif %}
      }

      setupKeyboardNavigation() {
        document.addEventListener('keydown', (e) => {
          // Only handle if section is in viewport
          const rect = this.getBoundingClientRect();
          const isVisible = rect.top < window.innerHeight && rect.bottom >= 0;
          
          if (!isVisible) return;

          if (e.key === 'ArrowLeft') {
            e.preventDefault();
            this.prevSlide();
          } else if (e.key === 'ArrowRight') {
            e.preventDefault();
            this.nextSlide();
          }
        });
      }

      setupAddToCart() {
        this.addToCartBtns.forEach(btn => {
          btn.addEventListener('click', (e) => {
            const productId = e.currentTarget.dataset.productId;
            this.addToCart(productId, e.currentTarget);
          });
        });
      }

      addToCart(productId, button) {
        const originalText = button.textContent;
        button.textContent = 'Adding...';
        button.disabled = true;
        document.dispatchEvent(new CustomEvent('theme:loading:start'));

        const cartAddUrl = `${window.routes?.cartAddUrl || '/cart/add'}.js`;

        fetch(cartAddUrl, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
          },
          credentials: 'same-origin',
          body: JSON.stringify({
            id: parseInt(productId, 10),
            quantity: 1
          })
        })
        .then(response => {
          button.removeAttribute('disabled');
          if (!response.ok) {
            document.dispatchEvent(new CustomEvent('theme:loading:end'));
            throw new Error('Add to cart failed');
          }
          return response.json();
        })
        .then(() => {
          button.textContent = 'Added!';
          if (window.theme?.pageType === 'cart' || window.theme?.cartType === 'page') {
            window.location.href = window.routes.cartUrl;
            return;
          }
          button.dispatchEvent(new CustomEvent('product:added', {
            bubbles: true,
            detail: {
              button: button,
              variant: null,
              quantity: 1,
              productAdded: true
            }
          }));
          setTimeout(() => {
            button.textContent = originalText;
            button.disabled = false;
          }, 2000);
        })
        .catch(error => {
          console.error('Error adding to cart:', error);
          document.dispatchEvent(new CustomEvent('theme:loading:end'));
          button.textContent = 'Error';
          setTimeout(() => {
            button.textContent = originalText;
            button.disabled = false;
          }, 2000);
        });
      }

      disconnectedCallback() {
        this.pauseSliderAutoplay();
        this.pauseCarouselAutoplay();
      }
    }

    customElements.define('split-screen-slider-{{ ai_gen_id }}', SplitScreenSlider{{ ai_gen_id }});
  })();
</script>

