<div data-section-id="{{ section.id }}" data-section-type="popups">
  {%- for block in section.blocks -%}
    {%- case block.type -%}
      {%- when 'newsletter' -%}
        {%- unless block.settings.show_only_on_index and template != 'index' -%}
          {%- unless block.settings.show_only_for_visitors and customer -%}
            {% capture popup_settings %}
              {
                "apparitionDelay": {{ block.settings.apparition_delay | json }},
                "showOnlyOnce": {{ block.settings.show_only_once | json }}
              }
            {% endcapture %}

            <aside class="modal modal--newsletter modal--newsletter-custom" data-popup-type="newsletter" data-popup-settings='{{ popup_settings }}' aria-hidden="true" {{ block.shopify_attributes }}>
              <div class="modal__dialog modal__dialog--custom" role="dialog">
                <div class="popup-newsletter popup-newsletter--overlay" style="background-image: url('{{ block.settings.image_url }}');">
                  
                  <button class="popup-newsletter__close link" data-action="close-popup" aria-label="{{ 'general.accessibility.close' | t }}">
                    {%- render 'icon', icon: 'close' -%}
                  </button>

                  <!-- Newsletter Form Content Overlay -->
                  <div class="popup-newsletter__content-wrapper">
                    {%- if block.settings.title != blank -%}
                      <h3 class="popup-newsletter__title heading">{{ block.settings.title | escape }}</h3>
                    {%- endif -%}

                    {%- if block.settings.content != blank -%}
                      <div class="popup-newsletter__content rte">
                        {{ block.settings.content }}
                      </div>
                    {%- endif -%}

                    {%- if block.settings.show_newsletter -%}
                      {%- form 'customer', id: 'newsletter-popup', class: 'form popup-newsletter__form' -%}
                        {%- if form.posted_successfully? -%}
                          <p class="alert alert--success alert--center">{{ 'general.popup.success' | t }}</p>
                        {%- else -%}
                          <input type="hidden" name="contact[tags]" value="newsletter">

                          <div class="form__input-wrapper form__input-wrapper--labelled">
                            <input id="newsletter-popup[email]" type="email" class="form__field form__field--text" name="contact[email]" placeholder="{{ 'general.popup.email_placeholder' | t }}" autofocus required="required">
                          </div>

                          <button class="button button--primary button--full popup-newsletter__button" type="submit">{{ 'general.popup.subscribe' | t }}</button>
                        {%- endif -%}
                      {%- endform -%}
                    {%- endif -%}

                    {%- if block.settings.show_checkbox -%}
                      <div class="popup-newsletter__checkbox">
                        <input type="checkbox" id="dont-show-again" class="popup-newsletter__checkbox-input">
                        <label for="dont-show-again" class="popup-newsletter__checkbox-label">
                          {{ block.settings.checkbox_text | default: "Don't show this popup again" }}
                        </label>
                      </div>
                    {%- endif -%}

                    {%- if block.settings.show_social -%}
                      <div class="popup-newsletter__social">
                        <a href="#" class="popup-newsletter__social-link" aria-label="Facebook">
                          <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                          </svg>
                        </a>
                      </div>
                    {%- endif -%}
                  </div>

                </div>
              </div>
            </aside>
          {%- endunless -%}
        {%- endunless -%}

      {%- when 'exit' -%}
        {%- unless block.settings.show_only_for_visitors and customer -%}
          {% capture popup_settings %}
            {
              "showOnlyOnce": {{ block.settings.show_only_once | json }}
            }
          {% endcapture %}

          <aside class="modal modal--exit-popup" data-popup-type="exit" data-popup-settings='{{ popup_settings }}' aria-hidden="true" {{ block.shopify_attributes }}>
            <div class="modal__dialog" role="dialog">
              <div class="exit-popup">
                {%- if block.settings.title != blank -%}
                  <h3 class="exit-popup__title heading">{{ block.settings.title | escape }}</h3>
                {%- endif -%}

                {%- if block.settings.subheading != blank -%}
                  <p class="exit-popup__subheading heading">{{ block.settings.subheading | escape }}</p>
                {%- endif -%}

                <button class="exit-popup__close link" data-action="close-popup" aria-label="{{ 'general.accessibility.close' | t }}">
                  {%- render 'icon', icon: 'close' -%}
                </button>

                {%- assign is_form_valid = false -%}

                {%- if block.settings.show_newsletter -%}
                  {%- form 'customer', id: 'exit-popup', class: 'form exit-popup__form' -%}
                    {%- if form.posted_successfully? -%}
                      {%- assign is_form_valid = true -%}
                      <p class="alert alert--success alert--center">{{ block.settings.success_message }}</p>
                    {%- else -%}
                      <input type="hidden" name="contact[tags]" value="newsletter">

                      <div class="form__input-wrapper form__input-wrapper--labelled">
                        <input id="exit-popup[email]" type="email" class="form__field form__field--large form__field--text" name="contact[email]" autofocus required="required">
                        <label for="exit-popup[email]" class="form__floating-label">{{ 'general.popup.email_placeholder' | t }}</label>
                      </div>

                      <button class="button button--primary button--extra-large button--full" type="submit">{{ block.settings.button_text | escape }}</button>
                    {%- endif -%}
                  {%- endform -%}
                {%- endif -%}

                {%- if block.settings.close_message != blank and is_form_valid == false -%}
                  <button class="exit-popup__pay-more link link--accented" data-action="close-popup">{{ block.settings.close_message }}</button>
                {%- endif -%}
              </div>
            </div>
          </aside>
        {%- endunless -%}
    {%- endcase -%}
  {%- endfor -%}
</div>

<style>
  /* Custom Newsletter Popup Styles */
  .modal--newsletter-custom .modal__dialog--custom {
    max-width: 850px;
    width: 90%;
    padding: 0;
    border-radius: 0;
  }

  .popup-newsletter--overlay {
    display: flex;
    align-items: center;
    min-height: 400px;
    position: relative;
    background-size: cover;
    background-position: center right;
    background-repeat: no-repeat;
    overflow: hidden;
  }

  .popup-newsletter__close {
    position: absolute;
    top: 10px;
    right: 10px;
    z-index: 100;
    background: rgba(0, 0, 0, 0.7);
    color: #fff;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
    border: 2px solid #fff;
  }

  .popup-newsletter__close:hover {
    background: rgba(0, 0, 0, 0.9);
    transform: scale(1.1);
  }

  /* Content Wrapper - Overlay on Left Side */
  .popup-newsletter__content-wrapper {
    max-width: 450px;
    width: 100%;
    padding: 40px;
    {% comment %} ====== Custom Css ===== {% endcomment %}

    {% comment %} background: rgba(255, 255, 255, 0.95); {% endcomment %}

    {% comment %} ======= End ======== {% endcomment %}


    position: relative;
    z-index: 2;
    margin-left: 0;
  }

  .popup-newsletter__title {
    font-size: 28px;
    font-weight: 700;
    margin: 0 0 12px 0;
    color: #1a1a1a;
    text-transform: uppercase;
    letter-spacing: 0px;
    line-height: 1.2;
  }

  .popup-newsletter__content {
    font-size: 14px;
    line-height: 1.5;
    color: #666;
    margin-bottom: 20px;
  }

  .popup-newsletter__content p {
    margin: 0;
  }

  .popup-newsletter__form {
    margin-bottom: 15px;
  }

  .popup-newsletter__form .form__input-wrapper {
    margin-bottom: 12px;
  }

  .popup-newsletter__form .form__field {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid #ddd;
    border-radius: 0;
    font-size: 14px;
    transition: border-color 0.3s ease;
    background: #fff;
  }

  .popup-newsletter__form .form__field::placeholder {
    color: #999;
    font-size: 14px;
  }

  .popup-newsletter__form .form__field:focus {
    border-color: #e30613;
    outline: none;
  }

  .popup-newsletter__button {
    background: #e30613 !important;
    color: #fff !important;
    padding: 5px 30px !important;
    font-size: 14px !important;
    font-weight: 700 !important;
    text-transform: uppercase;
    border: none !important;
    cursor: pointer;
    transition: all 0.3s ease;
    letter-spacing: 0.5px;
    border-radius: 0 !important;
  }

  .popup-newsletter__button:hover {
    background: #c00511 !important;
    box-shadow: 0 2px 8px rgba(227, 6, 19, 0.3);
  }

  .popup-newsletter__checkbox {
    display: flex;
    align-items: center;
    margin-bottom: 12px;
    margin-top: 2px;
  }

  .popup-newsletter__checkbox-input {
    margin-right: 8px;
    cursor: pointer;
    width: 16px;
    height: 16px;
  }

  .popup-newsletter__checkbox-label {
    font-size: 13px;
    color: #666;
    cursor: pointer;
    user-select: none;
  }

  .popup-newsletter__social {
    display: flex;
    gap: 10px;
    margin-top: 5px;
  }

  .popup-newsletter__social-link {
    width: 38px;
    height: 38px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #3b5998;
    color: #fff;
    border-radius: 50%;
    transition: all 0.3s ease;
  }

  .popup-newsletter__social-link:hover {
    background: #2d4373;
    transform: scale(1.05);
  }

  /* Responsive Design */
  @media (max-width: 768px) {
    .popup-newsletter--overlay {
      min-height: auto;
      background-size: cover;
      background-position: center;
    }

    .popup-newsletter__content-wrapper {
      max-width: 100%;
      padding: 35px 25px;
      background: rgba(255, 255, 255, 0.98);
    }

    .popup-newsletter__title {
      font-size: 22px;
    }

    .modal--newsletter-custom .modal__dialog--custom {
      width: 95%;
      margin: 20px auto;
    }
  }

  @media (max-width: 480px) {
    .popup-newsletter__content-wrapper {
      padding: 25px 20px;
    }

    .popup-newsletter__title {
      font-size: 20px;
    }

    .popup-newsletter__content {
      font-size: 13px;
    }

    .popup-newsletter__close {
      width: 28px;
      height: 28px;
    }
  }

  /* Success Message Styling */
  .popup-newsletter__form .alert--success {
    background: #4caf50;
    color: #fff;
    padding: 15px;
    border-radius: 4px;
    text-align: center;
  }
</style>

{% schema %}
{
  "name": "Popups",
  "max_blocks": 2,
  "blocks": [
    {
      "name": "Newsletter popup",
      "type": "newsletter",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "id": "show_only_on_index",
          "label": "Show only on home page",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_only_for_visitors",
          "label": "Disable for account holders",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_only_once",
          "label": "Show once to visitors",
          "default": true
        },
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "NEWSLETTER SUBSCRIBE"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Text",
          "default": "<p>Subscribe to the mailing list to receive updates on new arrivals, special offers and other discount information.</p>"
        },
        {
          "type": "checkbox",
          "id": "show_newsletter",
          "label": "Show newsletter form",
          "info": "Customers who subscribe will have their email address added to the \"accepts marketing\" [customer list](/admin/customers?query=&accepts_marketing=1).",
          "default": true
        },
        {
          "type": "text",
          "id": "image_url",
          "label": "Background Image URL",
          "default": "https://wingswest.com/static/frontend/Sm/autostore_child/en_US/images/bg-newsletter.jpg",
          "info": "Image for the right side of the popup"
        },
        {
          "type": "checkbox",
          "id": "show_checkbox",
          "label": "Show 'Don't show again' checkbox",
          "default": true
        },
        {
          "type": "text",
          "id": "checkbox_text",
          "label": "Checkbox text",
          "default": "Don't show this popup again"
        },
        {
          "type": "checkbox",
          "id": "show_social",
          "label": "Show social media icons",
          "default": true
        },
        {
          "type": "range",
          "id": "apparition_delay",
          "min": 0,
          "max": 15,
          "step": 1,
          "unit": "sec",
          "label": "Delay until the popup appears",
          "default": 5
        }
      ]
    },
    {
      "name": "Exit popup",
      "type": "exit",
      "limit": 1,
      "settings": [
        {
          "type": "paragraph",
          "content": "Enable an exit popup if user attempts to navigate away from current page as a means of influencing user action on store."
        },
        {
          "type": "paragraph",
          "content": "Only visible on desktop."
        },
        {
          "type": "checkbox",
          "id": "show_only_for_visitors",
          "label": "Disable for account holders",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_only_once",
          "label": "Show once to visitors",
          "default": true
        },
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "Get 15% off"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading",
          "default": "on your next order + exclusive offers"
        },
        {
          "type": "header",
          "content": "Newsletter"
        },
        {
          "type": "checkbox",
          "id": "show_newsletter",
          "label": "Show sign up form",
          "default": true
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button text",
          "default": "Get my 15% off",
          "visible_if": "{{ block.settings.show_newsletter }}"
        },
        {
          "type": "text",
          "id": "success_message",
          "label": "Success message",
          "info": "Text displayed after the customer has entered their email.",
          "default": "You will receive soon an email containing your discount code!",
          "visible_if": "{{ block.settings.show_newsletter }}"
        },
        {
          "type": "text",
          "id": "close_message",
          "label": "Close message",
          "default": "No thanks, I'd rather pay more"
        }
      ]
    }
  ]
}
{% endschema %}