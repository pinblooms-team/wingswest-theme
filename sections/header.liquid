<script>
/* ── Newsletter modal open/close ── */
(function () {
  function nlEl(id) { return document.getElementById(id); }

  function nlOpen() {
    var modal = nlEl('nl-modal'), ov = nlEl('nl-overlay');
    if (!modal) return;
    modal.style.display = 'block';
    document.body.style.overflow = 'hidden';
    ov.classList.add('nl-on');
    /* trigger animation next frame */
    requestAnimationFrame(function () {
      requestAnimationFrame(function () {
        modal.classList.add('nl-on');
      });
    });
    modal.setAttribute('aria-hidden', 'false');
  }

  function nlClose() {
    var modal = nlEl('nl-modal'), ov = nlEl('nl-overlay');
    if (!modal) return;
    modal.classList.remove('nl-on');
    ov.classList.remove('nl-on');
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    setTimeout(function () { modal.style.display = 'none'; }, 260);
  }

  document.addEventListener('click', function (e) {
    if (e.target.closest('#newsletter-icon-trigger')) { e.preventDefault(); nlOpen(); return; }
    if (e.target.id === 'nl-overlay') { nlClose(); return; }
    if (e.target.closest('#nl-close')) { nlClose(); return; }
  }, true);

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') { var m = nlEl('nl-modal'); if (m && m.classList.contains('nl-on')) nlClose(); }
  });
})();
</script>

