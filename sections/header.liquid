  document.documentElement.style.setProperty(
    '--header-height',
    document.getElementById('shopify-section-{{ section.id }}').clientHeight + 'px'
  );
</script>

<script>
(function () {
  var tid = null;
  function el(id) { return document.getElementById(id); }

  function open() {
    var panel = el('sdrw-panel'), ov = el('sdrw-overlay');
    if (!panel) return;
    panel.classList.add('on');
    panel.setAttribute('aria-hidden', 'false');
    ov.classList.add('on');
    document.body.classList.add('sdrw-lock');
    setTimeout(function () { var i = el('sdrw-input'); if (i) i.focus(); }, 80);
  }

  function close() {
    var panel = el('sdrw-panel'), ov = el('sdrw-overlay');
    if (!panel) return;
    panel.classList.remove('on');
    panel.setAttribute('aria-hidden', 'true');
    ov.classList.remove('on');
    document.body.classList.remove('sdrw-lock');
  }

  function doSearch(q) {
    var res = el('sdrw-results');
    if (!res) return;
    res.innerHTML = '<p class="sdrw-msg">Searching\u2026</p>';
    fetch(
      '/search/suggest.json?q=' + encodeURIComponent(q) +
      '&resources[type]=query,product,collection,page&resources[limit]=6' +
      '&resources[options][unavailable_products]=last'
    )
      .then(function (r) { return r.json(); })
      .then(function (d) { paint(d, q); })
      .catch(function () {
        var r2 = el('sdrw-results');
        if (r2) r2.innerHTML = '<p class="sdrw-msg">Could not load results.</p>';
      });
  }

  function paint(data, q) {
    var res = el('sdrw-results');
    if (!res) return;
    var r = (data.resources && data.resources.results) || {};
    var queries = r.queries || [], prods = r.products || [], cols = r.collections || [], pgs = r.pages || [];
    var h = '';

    if (queries.length) {
      h += '<p class="sdrw-h">Suggestions</p>';
      queries.forEach(function (q2) {
        h += '<a href="/search?type=product&q=' + encodeURIComponent(q2.text) + '" class="sdrw-link">'
          + '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>'
          + mark(esc(q2.text), q) + '</a>';
      });
    }
    if (prods.length) {
      h += '<p class="sdrw-h">Products</p>';
      prods.forEach(function (p) {
        var fi = p.featured_image, src = fi ? (fi.url || fi) : '';
        if (src) src += (src.indexOf('?') > -1 ? '&' : '?') + 'width=120';
        var raw = parseFloat(p.price_min || p.price || 0);
        var price = raw ? '$' + raw.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ',') : '';
        h += '<a href="' + p.url + '" class="sdrw-prod">'
          + '<div class="sdrw-thumb">' + (src ? '<img src="' + src + '" alt="" loading="lazy">' : '') + '</div>'
          + '<div class="sdrw-info"><span class="sdrw-title">' + mark(esc(p.title), q) + '</span>'
          + (price ? '<span class="sdrw-price">' + price + '</span>' : '') + '</div></a>';
      });
    }
    if (cols.length) {
      h += '<p class="sdrw-h">Collections</p>';
      cols.forEach(function (c) {
        h += '<a href="' + c.url + '" class="sdrw-link">'
          + '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>'
          + mark(esc(c.title), q) + '</a>';
      });
    }
    if (pgs.length) {
      h += '<p class="sdrw-h">Pages</p>';
      pgs.forEach(function (pg) {
        h += '<a href="' + pg.url + '" class="sdrw-link">'
          + '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>'
          + mark(esc(pg.title), q) + '</a>';
      });
    }
    if (!h) {
      h = '<p class="sdrw-msg">No results for &ldquo;<strong>' + esc(q) + '</strong>&rdquo;</p>';
    } else {
      h += '<a href="/search?type=product&q=' + encodeURIComponent(q) + '" class="sdrw-all">View all results &rarr;</a>';
    }
    res.innerHTML = h;
  }

  function esc(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
  function mark(s, q) {
    if (!q) return s;
    return s.replace(new RegExp('(' + q.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')', 'gi'), '<mark>$1</mark>');
  }

  /* Event delegation — capture phase — does NOT stopPropagation so nav hover is unaffected */
  document.addEventListener('click', function (e) {
    /* Fake search bar (desktop) */
    if (e.target.closest('#sdrw-fake-bar')) { e.preventDefault(); open(); return; }
    /* Mobile icon trigger */
    if (e.target.closest('#sdrw-mobile-trigger')) { e.preventDefault(); open(); return; }
    /* Overlay */
    if (e.target.id === 'sdrw-overlay') { close(); return; }
    /* Close button */
    if (e.target.closest('#sdrw-close')) { close(); return; }
    /* Clear button */
    if (e.target.closest('#sdrw-clear')) {
      var inp = el('sdrw-input'), clr = el('sdrw-clear'), res = el('sdrw-results');
      if (inp) { inp.value = ''; inp.focus(); }
      if (clr) clr.style.display = 'none';
      if (res) res.innerHTML = '';
      return;
    }
  }, true);

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') { var p = el('sdrw-panel'); if (p && p.classList.contains('on')) close(); }
    if (e.key === 'Enter' && e.target.id === 'sdrw-input') { e.preventDefault(); var f = el('sdrw-form'); if (f) f.submit(); }
  });

  document.addEventListener('input', function (e) {
    if (e.target.id !== 'sdrw-input') return;
    var q = e.target.value.trim();
    var clr = el('sdrw-clear');
    if (clr) clr.style.display = q.length ? 'flex' : 'none';
    clearTimeout(tid);
    if (!q.length) { var r = el('sdrw-results'); if (r) r.innerHTML = ''; return; }
    tid = setTimeout(function () { doSearch(q); }, 300);
  });

})();
</script>

<style>
